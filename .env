# Server Configuration
SERVER_PORT=8080

# Application Environment
# Options: "development" or "production"
# In production, Swagger UI is disabled
APP_ENV=development

# Datastore Toggles
# Options: "memory" or "postgres"
DB_TYPE=postgres

# PostgreSQL Configuration (Only used when DB_TYPE=postgres)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=todo_db
DB_USER=postgres
DB_PASSWORD=securepassword
DB_SSLMODE=disable

# Cache Toggles
# Options: "memory" or "redis"
# CACHE_TYPE=memory
# REDIS_URL=localhost:6379